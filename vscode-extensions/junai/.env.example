# Copy this file to .env and fill in local secrets.
# .env is gitignored.

# PyPI token used by junai-release / junai-publish-mcp
JUNAI_PYPI_TOKEN=

# VS Code Marketplace PAT for the full junai extension lane
JUNAI_VSCE_PAT=

# VS Code Marketplace PAT for the ptarmigan extension lane
PTARMIGAN_VSCE_PAT=

# Optional GitHub token for future non-interactive git/GitHub flows.
# sync.ps1 does not currently require this.
GITHUB_PAT=
