PAYLOAD_DIR = Path(__file__).parent.parent / "fixtures" / "payloads"
SAMPLE_PATH = PAYLOAD_DIR / "{{source_slug}}" / "sample.json"
STATE_PATH = PAYLOAD_DIR / "{{source_slug}}" / "_contract_state.json"

# ---------------------------------------------------------------------------
# Schema evolution toggle
# ---------------------------------------------------------------------------
# Set to True once the upstream schema is stable. While False, drift
# detection emits warnings; when True, drift causes hard test failures.
#
# Prefer explicit env override in CI:
#   CONTRACT_SCHEMA_FROZEN=1   -> hard mode
#   CONTRACT_SCHEMA_FROZEN=0   -> soft mode
#
# If env is missing, _resolve_schema_frozen() applies fallback logic.


def _truthy_env(value: str) -> bool | None:
    """Parse common truthy/falsey strings; return None if unknown."""
    normalized = value.strip().lower()
    if normalized in {"1", "true", "yes", "on", "frozen", "hard"}:
        return True
    if normalized in {"0", "false", "no", "off", "evolving", "soft"}:
        return False
    return None


def _load_state_file_flag() -> bool | None:
    """Read optional schema-frozen flag from _contract_state.json.

    Expected shape:
    {
      "schema_frozen": true,
      "source": "agent",
      "note": "optional"
    }
    """
    if not STATE_PATH.exists():
        return None
    try:
        state = json.loads(STATE_PATH.read_text(encoding="utf-8"))
        value = state.get("schema_frozen")
        if isinstance(value, bool):
            return value
        if isinstance(value, str):
            return _truthy_env(value)
    except Exception as exc:  # pragma: no cover - defensive fallback
        warnings.warn(
            f"Could not parse contract state file {STATE_PATH}: {exc}. "
            "Falling back to next freeze resolution rule.",
            stacklevel=2,
        )
    return None


def _resolve_schema_frozen() -> bool:
    """Resolve drift mode using explicit override + deterministic fallbacks."""
    env_value = os.getenv("CONTRACT_SCHEMA_FROZEN")
    if env_value is not None:
        parsed = _truthy_env(env_value)
        if parsed is not None:
            return parsed
        warnings.warn(
            "CONTRACT_SCHEMA_FROZEN has unrecognized value "
            f"'{env_value}'. Expected one of: 1/0, true/false, frozen/evolving. "
            "Continuing with fallback resolution.",
            stacklevel=2,
        )

    state_flag = _load_state_file_flag()
    if state_flag is not None:
        return state_flag

    ci_value = os.getenv("CI", "")
    ci_mode = _truthy_env(ci_value) is True
    if ci_mode and SAMPLE_PATH.exists():
        warnings.warn(
            "Auto-freeze fallback enabled (CI=true, sample.json present, no explicit "
            "CONTRACT_SCHEMA_FROZEN/state flag). Running HARD drift mode. "
            "Set CONTRACT_SCHEMA_FROZEN explicitly to override.",
            stacklevel=2,
        )
        return True

    return False


SCHEMA_FROZEN = _resolve_schema_frozen()

# ---------------------------------------------------------------------------
# Exclusion allow-list  (Layer 3 of the three-layer defence)
# ---------------------------------------------------------------------------
# Keys that are intentionally NOT typed in the DTO.  Use dot-path globs
# (fnmatch syntax).  Always add a comment with a ticket ref or justification.
# Review periodically — remove entries once the key is typed or removed upstream.
KNOWN_EXCLUDED_KEYS: dict[str, set[str]] = {
    # Example entries (delete and replace with real ones):
    # "root.section.*": {"experimental_field"},  # TICKET-123: upstream experiment
    # "surveys.*": {"internal_metadata"},         # TICKET-456: not consumer-facing
}


# ====================== helpers =============================================

def _unwrap_optional(tp):
    """Extract T from Optional[T] / T | None."""
    origin = get_origin(tp)
    if origin is Union:
        args = [a for a in get_args(tp) if a is not type(None)]
        return args[0] if len(args) == 1 else tp
    return tp


def _resolve_child(tp):
    """If tp is list[X] return X; if BaseModel subclass, return it; else None."""
    tp = _unwrap_optional(tp)
    if isinstance(tp, type) and issubclass(tp, BaseModel):
        return tp
    origin = get_origin(tp)
    if origin is list:
        inner = get_args(tp)[0]
        inner = _unwrap_optional(inner)
        if isinstance(inner, type) and issubclass(inner, BaseModel):
            return inner
    return None


def _collect_dropped_keys(
    data,
    model_cls: type[BaseModel],
    prefix: str = "",
    dropped: list[str] | None = None,
) -> list[str]:
    """Recursively walk JSON data vs model fields; return unmatched key paths.

    Walks nested dicts and lists-of-dicts at every depth level, not just
    top-level keys.  Keys matching KNOWN_EXCLUDED_KEYS are silently skipped.
    """
    if dropped is None:
        dropped = []

    if isinstance(data, list):
        for item in data:
            if isinstance(item, dict):
                _collect_dropped_keys(item, model_cls, prefix, dropped)
        return dropped

    if not isinstance(data, dict):
        return dropped

    hints = get_type_hints(model_cls, include_extras=True)
    alias_map: dict[str, tuple[str, type | None]] = {}
    for field_name, field_info in model_cls.model_fields.items():
        alias = field_info.alias or field_name
        alias_map[alias] = (field_name, hints.get(field_name))

    for key in data:
        full_path = f"{prefix}.{key}" if prefix else key

        # Check exclusion allow-list
        if any(
            fnmatch(full_path, pattern) and key in excl
            for pattern, excl in KNOWN_EXCLUDED_KEYS.items()
        ):
            continue

        if key not in alias_map:
            dropped.append(full_path)
        else:
            _field_name, type_hint = alias_map[key]
            if type_hint is not None:
                child_model = _resolve_child(type_hint)
                if child_model is not None:
                    _collect_dropped_keys(
                        data[key], child_model, full_path, dropped,
                    )

    return dropped


def _report_drift(dropped: list[str], context: str) -> None:
    """Emit soft warning or hard assertion depending on SCHEMA_FROZEN."""
    if not dropped:
        return

    msg = (
        f"Coverage gap in {context} — "
        f"{len(dropped)} key(s) forwarded via model_extra:\n"
        + "\n".join(f"  - {k}" for k in dropped)
        + "\nData is NOT lost (extra='allow'), but typed fields "
        "give IDE support and validation."
    )

    if SCHEMA_FROZEN:
        raise AssertionError(msg)
    else:
        warnings.warn(msg, stacklevel=2)


