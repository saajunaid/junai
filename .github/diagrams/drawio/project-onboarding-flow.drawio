        <mxCell id="m_arr_3_4" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#6C8EBF;strokeWidth=2;rounded=1;" edge="1" source="mstep3" target="mstep4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m_arr_4_5" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#555555;strokeWidth=2;rounded=1;" edge="1" source="mstep4" target="mstep5" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m_arr_5_6" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#D6A656;strokeWidth=2;rounded=1;" edge="1" source="mstep5" target="mstep6" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m_arr_6_7" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#D6A656;strokeWidth=2;rounded=1;" edge="1" source="mstep6" target="mstep7" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m_arr_8_9" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#555555;strokeWidth=2;rounded=1;" edge="1" source="mstep7" target="mstep9" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Decision → Pipeline (left) -->
        <mxCell id="m_arr_9_9a" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#B85450;strokeWidth=2;rounded=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="mstep9" target="mstep9a" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m_arr_9_9a_lbl" value="Pipeline" style="edgeLabel;html=1;fontSize=10;fontFamily=Arial;fontColor=#B85450;fontStyle=1;resizable=0;" vertex="1" connectable="0" parent="m_arr_9_9a">
          <mxGeometry relative="0.4" as="geometry"/>
        </mxCell>

        <!-- Decision → Direct agents (bottom/centre) -->
        <mxCell id="m_arr_9_9c" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#4472C4;strokeWidth=2;rounded=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="mstep9" target="mstep9c" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m_arr_9_9c_lbl" value="Direct agents" style="edgeLabel;html=1;fontSize=10;fontFamily=Arial;fontColor=#4472C4;fontStyle=1;resizable=0;" vertex="1" connectable="0" parent="m_arr_9_9c">
          <mxGeometry relative="0.5" as="geometry"/>
        </mxCell>

        <!-- Decision → Open chat (right) -->
        <mxCell id="m_arr_9_9b" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#2D6A2E;strokeWidth=2;rounded=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="mstep9" target="mstep9b" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m_arr_9_9b_lbl" value="Open chat" style="edgeLabel;html=1;fontSize=10;fontFamily=Arial;fontColor=#2D6A2E;fontStyle=1;resizable=0;" vertex="1" connectable="0" parent="m_arr_9_9b">
          <mxGeometry relative="0.4" as="geometry"/>
        </mxCell>

        <!-- All three branches → converge -->
        <mxCell id="m_arr_9a_10" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#B85450;strokeWidth=2;rounded=1;entryX=0.15;entryY=0;entryDx=0;entryDy=0;" edge="1" source="mstep9a" target="mstep10" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m_arr_9c_10" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#4472C4;strokeWidth=2;rounded=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="mstep9c" target="mstep10" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m_arr_9b_10" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#2D6A2E;strokeWidth=2;rounded=1;entryX=0.85;entryY=0;entryDx=0;entryDy=0;" edge="1" source="mstep9b" target="mstep10" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- PHASE 0 — ON-RAMP (replaces SCAFFOLD)           -->
        <!-- band: y=108 h=215                               -->
        <!-- ═══════════════════════════════════════════════ -->
        <mxCell id="mphase0_bg" value=""
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#7B7B7B;strokeWidth=2;arcSize=2;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="108" width="1020" height="215" as="geometry"/>
        </mxCell>
        <mxCell id="mphase0_lbl" value="ON-RAMP"
          style="whiteSpace=wrap;html=1;fillColor=#DCDCDC;strokeColor=#7B7B7B;strokeWidth=1;fontSize=13;fontStyle=1;fontFamily=Arial;fontColor=#333333;align=center;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="108" width="110" height="215" as="geometry"/>
        </mxCell>

        <!-- step M1: pre-flight -->
        <mxCell id="mstep1"
          value="&lt;b&gt;① Pre-flight checks&lt;/b&gt;&lt;br&gt;&lt;font color='#555555' style='font-size:11px'&gt;Git initialized in project?&lt;/font&gt;&lt;br&gt;&lt;font face='Courier New' size='2' color='#333333'&gt;If no: cd E:\Projects\my-project &amp;amp;&amp;amp; git init &amp;amp;&amp;amp; git add . &amp;amp;&amp;amp; git commit -m &quot;Initial commit&quot;&lt;/font&gt;&lt;br&gt;&lt;font color='#1F3864' style='font-size:10px'&gt;&lt;b&gt;Note:&lt;/b&gt; junai needs a git root to place .github/ config  ·  Remote (GitHub/Gitea) is not required at this point&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7B7B7B;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingRight=8;spacingTop=5;spacingBottom=5;"
          vertex="1" parent="1">
          <mxGeometry x="145" y="138" width="865" height="95" as="geometry"/>
        </mxCell>

        <!-- step M2: open in VS Code -->
        <mxCell id="mstep2"
          value="&lt;b&gt;② Open project in VS Code&lt;/b&gt;&lt;br&gt;&lt;font face='Courier New' size='2' color='#2A2A2A'&gt;code E:\Projects\my-project&lt;/font&gt;&lt;br&gt;&lt;font color='#1F3864' style='font-size:10px'&gt;&lt;b&gt;Note:&lt;/b&gt; junai extension activates automatically when VS Code opens the git root folder&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7B7B7B;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingRight=8;spacingTop=5;spacingBottom=5;"
          vertex="1" parent="1">
          <mxGeometry x="145" y="245" width="865" height="68" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- PHASE 2 — ACTIVATE                              -->
        <!-- band: y=333 h=230                               -->
        <!-- ═══════════════════════════════════════════════ -->
        <mxCell id="mphase2_bg" value=""
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;strokeWidth=2;arcSize=2;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="333" width="1020" height="230" as="geometry"/>
        </mxCell>
        <mxCell id="mphase2_lbl" value="ACTIVATE"
          style="whiteSpace=wrap;html=1;fillColor=#9DC3E6;strokeColor=#6C8EBF;strokeWidth=1;fontSize=14;fontStyle=1;fontFamily=Arial;fontColor=#1F3864;align=center;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="333" width="110" height="230" as="geometry"/>
        </mxCell>

        <!-- step M3: update agent pool -->
        <mxCell id="mstep3"
          value="&lt;b&gt;③ Sync the agent pool into your project&lt;/b&gt;&lt;br&gt;&lt;font face='Courier New' size='2' color='#2A2A2A'&gt;Ctrl+Shift+P → &quot;junai: Update Agent Pool&quot;&lt;/font&gt;&lt;br&gt;&lt;font color='#888888' style='font-size:10px'&gt;Copies agents/skills/tools into .github/ — merges with existing files, nothing overwritten&lt;/font&gt;&lt;br&gt;&lt;font color='#B85450' style='font-size:10px'&gt;&lt;b&gt;⚠ Do NOT use &quot;junai: Initialize Agent Pipeline&quot; here — it will overwrite copilot-instructions.md and project-config.md&lt;/b&gt;&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6C8EBF;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingRight=8;spacingTop=5;spacingBottom=5;"
          vertex="1" parent="1">
          <mxGeometry x="145" y="363" width="865" height="95" as="geometry"/>
        </mxCell>

        <!-- step M4: pool synced -->
        <mxCell id="mstep4"
          value="&lt;b&gt;④ Agent pool synced into your existing project&lt;/b&gt;&lt;br&gt;&lt;font color='#555555' style='font-size:11px'&gt;agents/ · skills/ · recipes/ · instructions/ → .github/  |  .claude/  |  .codex/  ·  All pre-existing files preserved  ·  &lt;b&gt;pipeline-state.json NOT auto-created&lt;/b&gt; — create manually from recipe template if orchestration is needed&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6C8EBF;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingRight=8;spacingTop=5;spacingBottom=5;"
          vertex="1" parent="1">
          <mxGeometry x="145" y="470" width="865" height="63" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- PHASE 3 — AIM                                   -->
        <!-- band: y=573 h=310                               -->
        <!-- ═══════════════════════════════════════════════ -->
        <mxCell id="mphase3_bg" value=""
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D6A656;strokeWidth=2;arcSize=2;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="573" width="1020" height="310" as="geometry"/>
        </mxCell>
        <mxCell id="mphase3_lbl" value="AIM"
          style="whiteSpace=wrap;html=1;fillColor=#F4C07A;strokeColor=#D6A656;strokeWidth=1;fontSize=14;fontStyle=1;fontFamily=Arial;fontColor=#7D4E00;align=center;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="573" width="110" height="310" as="geometry"/>
        </mxCell>

        <!-- step M5: select profile -->
        <mxCell id="mstep5"
          value="&lt;b&gt;⑤ Select Project Profile&lt;/b&gt;&lt;br&gt;&lt;font face='Courier New' size='2' color='#2A2A2A'&gt;Ctrl+Shift+P → &quot;junai: Select Project Profile&quot;&lt;/font&gt;&lt;br&gt;&lt;font color='#555555' style='font-size:11px'&gt;QuickPick: react-fastapi-vite-mssql  ·  streamlit-mssql-enterprise  ·  org1-telecom-ops  ·  …  ·  Pick what matches your stack&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D6A656;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingRight=8;spacingTop=5;spacingBottom=5;"
          vertex="1" parent="1">
          <mxGeometry x="145" y="603" width="865" height="82" as="geometry"/>
        </mxCell>

        <!-- step M6: select recipe -->
        <mxCell id="mstep6"
          value="&lt;b&gt;⑥ Select Recipe (QuickPick prompted automatically after profile)&lt;/b&gt;&lt;br&gt;&lt;font color='#555555' style='font-size:11px'&gt;Pick the recipe that best maps to your project goal, or choose &quot;none&quot; to proceed with agent defaults&lt;/font&gt;&lt;br&gt;&lt;font face='Courier New' size='2' color='#555555'&gt;Written to: .github/project-config.md  →  | recipe | enterprise-dashboard |&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D6A656;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingRight=8;spacingTop=5;spacingBottom=5;"
          vertex="1" parent="1">
          <mxGeometry x="145" y="698" width="865" height="82" as="geometry"/>
        </mxCell>

        <!-- step M7: place assets -->
        <mxCell id="mstep7"
          value="&lt;b&gt;⑦ Place your assets in scratch/ (create if it does not exist)&lt;/b&gt;&lt;br&gt;&lt;font face='Courier New' size='2' color='#2A2A2A'&gt;scratch/data/     ←  CSV · JSON · XLSX · or note your DB host + table name(s)&lt;br&gt;scratch/mockups/  ←  dashboard-mockup.html  (or any HTML/image mockup)&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D6A656;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingRight=8;spacingTop=5;spacingBottom=5;"
          vertex="1" parent="1">
          <mxGeometry x="145" y="793" width="865" height="60" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- PHASE 4 — RUN                                   -->
        <!-- band: y=893 h=455                               -->
        <!-- ═══════════════════════════════════════════════ -->
        <mxCell id="mphase4_bg" value=""
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;strokeWidth=2;arcSize=2;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="893" width="1020" height="455" as="geometry"/>
        </mxCell>
        <mxCell id="mphase4_lbl" value="RUN"
          style="whiteSpace=wrap;html=1;fillColor=#E8928E;strokeColor=#B85450;strokeWidth=1;fontSize=14;fontStyle=1;fontFamily=Arial;fontColor=#7A1F1F;align=center;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="893" width="110" height="455" as="geometry"/>
        </mxCell>

        <!-- Decision diamond — centered: x=444 -->
        <mxCell id="mstep9"
          value="&lt;b&gt;⑧ How do you want to work?&lt;/b&gt;"
          style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B85450;strokeWidth=2;fontSize=13;fontFamily=Arial;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="444" y="926" width="290" height="72" as="geometry"/>
        </mxCell>

        <!-- Branch A: Full Pipeline -->
        <mxCell id="mstep9a"
          value="&lt;b&gt;Full Pipeline&lt;/b&gt;&lt;br&gt;&lt;font face='Courier New' size='2' color='#7A1F1F'&gt;@Orchestrator Start a new pipeline.&lt;br&gt;Data in scratch/data/, mockup in&lt;br&gt;scratch/mockups/. Build [feature].&lt;/font&gt;&lt;br&gt;&lt;font color='#888888' style='font-size:10px'&gt;Stage machine controls routing + gates&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B85450;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingRight=8;spacingTop=5;spacingBottom=5;"
          vertex="1" parent="1">
          <mxGeometry x="145" y="1046" width="255" height="110" as="geometry"/>
        </mxCell>

        <!-- Branch B: Direct Agent Call -->
        <mxCell id="mstep9c"
          value="&lt;b&gt;Direct Agent Call&lt;/b&gt;&lt;br&gt;&lt;font face='Courier New' size='2' color='#1F3864'&gt;@Implement [describe the task]&lt;br&gt;@Planner Plan the [feature]&lt;br&gt;@Frontend Developer Build [UI]&lt;/font&gt;&lt;br&gt;&lt;font color='#888888' style='font-size:10px'&gt;Agents + skills load, no state machine&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4472C4;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingRight=8;spacingTop=5;spacingBottom=5;"
          vertex="1" parent="1">
          <mxGeometry x="432" y="1046" width="255" height="110" as="geometry"/>
        </mxCell>

        <!-- Branch C: Open Chat -->
        <mxCell id="mstep9b"
          value="&lt;b&gt;Open Chat (any AI tool)&lt;/b&gt;&lt;br&gt;&lt;font face='Courier New' size='2' color='#1E4620'&gt;Build [feature]. Data in scratch/data/.&lt;br&gt;Mockup in scratch/mockups/.&lt;br&gt;Follow the enterprise-dashboard recipe.&lt;/font&gt;&lt;br&gt;&lt;font color='#888888' style='font-size:10px'&gt;Claude Code · Cursor · Windsurf · Copilot&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2D6A2E;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingRight=8;spacingTop=5;spacingBottom=5;"
          vertex="1" parent="1">
          <mxGeometry x="720" y="1046" width="265" height="110" as="geometry"/>
        </mxCell>

        <!-- Converge -->
        <mxCell id="mstep10"
          value="&lt;b&gt;⑨ Recipe guides delivery — all three paths converge here&lt;/b&gt;&lt;br&gt;&lt;font color='#555555' style='font-size:11px'&gt;Reads project-config.md → recipe field → follows phases:  1. Data Intake → 2. Adapter → 3. Normalize → 4. Display DTO → 5. Contract Test → 6. API Surface → 7. UI Design → 8. Implement → 9. Verify&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B85450;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingRight=8;spacingTop=5;spacingBottom=5;"
          vertex="1" parent="1">
          <mxGeometry x="145" y="1195" width="865" height="120" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- NOTE                                            -->
        <!-- ═══════════════════════════════════════════════ -->
        <mxCell id="m_note"
          value="&lt;i&gt;Your existing code stays untouched — junai only adds agent/skill pool files.  ·  No pipeline-state.json created automatically — add manually if needed.  ·  &lt;b&gt;Update Agent Pool = sync; Initialize Agent Pipeline = first-time setup only.&lt;/b&gt;&lt;/i&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;strokeWidth=1.5;fontSize=12;fontFamily=Arial;fontColor=#666666;"
          vertex="1" parent="1">
          <mxGeometry x="145" y="1428" width="865" height="36" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- PAGE 3 — Three Flows at a Glance (reference card)                  -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <diagram name="Three Flows at a Glance" id="three-flows">
    <mxGraphModel defaultFontFamily="Arial" dx="0" dy="0" page="1" pageScale="1" pageWidth="1060" pageHeight="640" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="t_title" value="junai Onboarding — Three Flows at a Glance"
          style="text;html=1;fontSize=22;fontStyle=1;fontFamily=Arial;align=center;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="80" y="15" width="900" height="42" as="geometry"/>
        </mxCell>

        <!-- Subtitle -->
        <mxCell id="t_subtitle" value="Which command do I use? Choose based on the project state at the time you are onboarding."
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;strokeWidth=1.5;fontSize=12;fontFamily=Arial;fontColor=#555555;"
          vertex="1" parent="1">
          <mxGeometry x="80" y="65" width="900" height="32" as="geometry"/>
        </mxCell>

        <!-- Flow A header (green) -->
        <mxCell id="t_a_hdr" value="Flow A — New Project with Recipe"
          style="whiteSpace=wrap;html=1;fillColor=#A9D18E;strokeColor=#82B366;strokeWidth=2;fontSize=14;fontStyle=1;fontFamily=Arial;fontColor=#1E4620;align=center;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="115" width="320" height="50" as="geometry"/>
        </mxCell>

        <!-- Flow B header (grey) -->
        <mxCell id="t_b_hdr" value="Flow B — New Project, Agents Only"
          style="whiteSpace=wrap;html=1;fillColor=#DCDCDC;strokeColor=#7B7B7B;strokeWidth=2;fontSize=14;fontStyle=1;fontFamily=Arial;fontColor=#333333;align=center;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="370" y="115" width="320" height="50" as="geometry"/>
        </mxCell>

        <!-- Flow C header (blue) -->
        <mxCell id="t_c_hdr" value="Flow C — Mid-Flight / Existing Project"
          style="whiteSpace=wrap;html=1;fillColor=#9DC3E6;strokeColor=#6C8EBF;strokeWidth=2;fontSize=14;fontStyle=1;fontFamily=Arial;fontColor=#1F3864;align=center;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="720" y="115" width="320" height="50" as="geometry"/>
        </mxCell>

        <!-- Flow A body -->
        <mxCell id="t_a_body"
          value="&lt;b&gt;When:&lt;/b&gt; Brand new project using structured 9-phase delivery&lt;br&gt;&lt;br&gt;&lt;b&gt;Command:&lt;/b&gt;&lt;br&gt;&lt;font face='Courier New' size='2'&gt;junai: Initialize Agent Pipeline&lt;/font&gt;&lt;br&gt;&lt;i&gt;(VS Code notification or Ctrl+Shift+P)&lt;/i&gt;&lt;br&gt;&lt;br&gt;&lt;font color='#555555' style='font-size:11px'&gt;↳ Prompts for &lt;b&gt;profile&lt;/b&gt; (react-fastapi-vite-mssql, etc.)&lt;br&gt;↳ Then prompts for &lt;b&gt;recipe&lt;/b&gt; (enterprise-dashboard, none, etc.)&lt;br&gt;Recipe is a sub-step — separate from the pipeline itself&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Creates:&lt;/b&gt;&lt;br&gt;• Full agent + skill pool in .github/&lt;br&gt;• pipeline-state.json for orchestration&lt;br&gt;• project-config.md with profile + recipe&lt;br&gt;&lt;br&gt;&lt;font color='#1E4620'&gt;&lt;b&gt;← Recommended default for new vmie projects&lt;/b&gt;&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=10;spacingRight=10;spacingTop=8;spacingBottom=8;verticalAlign=top;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="175" width="320" height="430" as="geometry"/>
        </mxCell>

        <!-- Flow B body -->
        <mxCell id="t_b_body"
          value="&lt;b&gt;When:&lt;/b&gt; New project where you want AI agent assistance but &lt;i&gt;not&lt;/i&gt; structured pipeline orchestration&lt;br&gt;&lt;br&gt;&lt;b&gt;Command:&lt;/b&gt;&lt;br&gt;&lt;font face='Courier New' size='2'&gt;junai: Initialize Agent Pool&lt;/font&gt;&lt;br&gt;&lt;i&gt;(VS Code notification or Ctrl+Shift+P)&lt;/i&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Creates:&lt;/b&gt;&lt;br&gt;• Full agent + skill pool in .github/&lt;br&gt;• project-config.md (profile only, no recipe)&lt;br&gt;• &lt;b&gt;No&lt;/b&gt; pipeline-state.json&lt;br&gt;&lt;br&gt;&lt;b&gt;After deploy:&lt;/b&gt;&lt;br&gt;Prompts to Select Profile or Set Recipe&lt;br&gt;&lt;br&gt;&lt;font color='#1E4620'&gt;&lt;b&gt;Available in junai-vscode 0.9.1+&lt;/b&gt;&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7B7B7B;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=10;spacingRight=10;spacingTop=8;spacingBottom=8;verticalAlign=top;"
          vertex="1" parent="1">
          <mxGeometry x="370" y="175" width="320" height="430" as="geometry"/>
        </mxCell>

        <!-- Flow C body -->
        <mxCell id="t_c_body"
          value="&lt;b&gt;When:&lt;/b&gt; Project already exists mid-development. Adding junai without disrupting existing work.&lt;br&gt;&lt;br&gt;&lt;b&gt;Command:&lt;/b&gt;&lt;br&gt;&lt;font face='Courier New' size='2'&gt;junai: Update Agent Pool&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Then configure:&lt;/b&gt;&lt;br&gt;&lt;font face='Courier New' size='2'&gt;junai: Select Project Profile&lt;/font&gt;&lt;br&gt;&lt;font face='Courier New' size='2'&gt;junai: Set Recipe&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Creates:&lt;/b&gt;&lt;br&gt;• Syncs latest agents/skills into .github/&lt;br&gt;• All existing files preserved — no overwrites&lt;br&gt;• pipeline-state.json NOT auto-created&lt;br&gt;&lt;br&gt;&lt;font color='#B85450'&gt;&lt;b&gt;⚠ Do NOT use &quot;Initialize Agent Pipeline&quot; on mid-flight projects — it will overwrite project-config.md and copilot-instructions.md&lt;/b&gt;&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6C8EBF;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=10;spacingRight=10;spacingTop=8;spacingBottom=8;verticalAlign=top;"
          vertex="1" parent="1">
          <mxGeometry x="720" y="175" width="320" height="430" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- PAGE 4 — Command Reference                                          -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <diagram name="Command Reference" id="cmd-reference">
    <mxGraphModel defaultFontFamily="Arial" dx="0" dy="0" page="1" pageScale="1" pageWidth="1060" pageHeight="580" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="cr_title" value="junai VS Code — Command Reference"
          style="text;html=1;fontSize=22;fontStyle=1;fontFamily=Arial;align=center;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="80" y="15" width="900" height="42" as="geometry"/>
        </mxCell>

        <mxCell id="cr_subtitle"
          value="All commands via Ctrl+Shift+P. &lt;b&gt;Pipeline&lt;/b&gt; = orchestration state machine (pipeline-state.json).  &lt;b&gt;Recipe&lt;/b&gt; = delivery methodology (enterprise-dashboard, etc.). These are separate concerns."
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;strokeWidth=1.5;fontSize=12;fontFamily=Arial;fontColor=#555555;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="65" width="1020" height="30" as="geometry"/>
        </mxCell>

        <!-- Existing Commands header -->
        <mxCell id="cr_exist_hdr" value="All Commands (11)"
          style="whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;strokeWidth=2;fontSize=13;fontStyle=1;fontFamily=Arial;fontColor=#1E4620;align=left;spacingLeft=10;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="105" width="1020" height="26" as="geometry"/>
        </mxCell>

        <mxCell id="cr_c1"
          value="&lt;font face='Courier New' size='2'&gt;&lt;b&gt;Initialize Agent Pipeline&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style='font-size:10px' color='#555555'&gt;First-time setup — copies pool, prompts for profile then recipe (separate sub-steps), creates pipeline-state.json&lt;br&gt;&lt;b&gt;New projects only&lt;/b&gt; — overwrites existing config&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingTop=5;verticalAlign=top;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="140" width="320" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="cr_c2"
          value="&lt;font face='Courier New' size='2'&gt;&lt;b&gt;Select Project Profile&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style='font-size:10px' color='#555555'&gt;Set or change the project tech-stack profile (react-fastapi-vite-mssql, etc.). Writes to project-config.md.&lt;br&gt;&lt;b&gt;Any project, any time&lt;/b&gt;&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingTop=5;verticalAlign=top;"
          vertex="1" parent="1">
          <mxGeometry x="370" y="140" width="320" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="cr_c3"
          value="&lt;font face='Courier New' size='2'&gt;&lt;b&gt;Update Agent Pool&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style='font-size:10px' color='#555555'&gt;Sync latest agents/skills from agent-sandbox pool. Preserves all existing project files.&lt;br&gt;&lt;b&gt;Any already-initialized project — safe for mid-flight&lt;/b&gt;&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingTop=5;verticalAlign=top;"
          vertex="1" parent="1">
          <mxGeometry x="720" y="140" width="320" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="cr_c4"
          value="&lt;font face='Courier New' size='2'&gt;&lt;b&gt;Show Pipeline Status&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style='font-size:10px' color='#555555'&gt;Display current pipeline stage, progress, and gate status from pipeline-state.json.&lt;br&gt;&lt;b&gt;Projects with an active pipeline&lt;/b&gt;&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingTop=5;verticalAlign=top;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="230" width="320" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="cr_c5"
          value="&lt;font face='Courier New' size='2'&gt;&lt;b&gt;Set Pipeline Mode&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style='font-size:10px' color='#555555'&gt;Switch orchestration mode: supervised / assisted / autopilot. Controls how much @Orchestrator auto-advances stages.&lt;br&gt;&lt;b&gt;Active pipeline projects&lt;/b&gt;&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingTop=5;verticalAlign=top;"
          vertex="1" parent="1">
          <mxGeometry x="370" y="230" width="320" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="cr_c6"
          value="&lt;font face='Courier New' size='2'&gt;&lt;b&gt;Remove from this project&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style='font-size:10px' color='#555555'&gt;Offboarding — removes junai pool files and config. Does not touch application code.&lt;br&gt;&lt;b&gt;Decommissioning junai from a project&lt;/b&gt;&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingTop=5;verticalAlign=top;"
          vertex="1" parent="1">
          <mxGeometry x="720" y="230" width="320" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="cr_c7"
          value="&lt;font face='Courier New' size='2'&gt;&lt;b&gt;Probe Autopilot Chat Commands&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style='font-size:10px' color='#555555'&gt;Dry-run test of autopilot commands — no changes made. Verify setup before enabling autopilot mode.&lt;br&gt;&lt;b&gt;Any time, safe to run&lt;/b&gt;&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingTop=5;verticalAlign=top;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="320" width="320" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="cr_c8"
          value="&lt;font face='Courier New' size='2'&gt;&lt;b&gt;Run Coordinator Mode&lt;/b&gt;&lt;/font&gt;  &lt;font color='#D6A656'&gt;&lt;i&gt;[experimental]&lt;/i&gt;&lt;/font&gt;&lt;br&gt;&lt;font style='font-size:10px' color='#555555'&gt;Multi-agent coordination mode. Enable via junai.experimental.coordinator setting before use.&lt;br&gt;&lt;b&gt;Complex multi-agent workflows&lt;/b&gt;&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9F0;strokeColor=#D6A656;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingTop=5;verticalAlign=top;"
          vertex="1" parent="1">
          <mxGeometry x="370" y="320" width="320" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="cr_c9"
          value="&lt;font face='Courier New' size='2'&gt;&lt;b&gt;Deep Plan&lt;/b&gt;&lt;/font&gt;  &lt;font color='#D6A656'&gt;&lt;i&gt;[experimental]&lt;/i&gt;&lt;/font&gt;&lt;br&gt;&lt;font style='font-size:10px' color='#555555'&gt;Generate a structured implementation plan. Enable via junai.experimental.deepPlan setting before use.&lt;br&gt;&lt;b&gt;Planning a new feature or phase&lt;/b&gt;&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9F0;strokeColor=#D6A656;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingTop=5;verticalAlign=top;"
          vertex="1" parent="1">
          <mxGeometry x="720" y="320" width="320" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="cr_c10"
          value="&lt;font face='Courier New' size='2'&gt;&lt;b&gt;Initialize Agent Pool&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style='font-size:10px' color='#555555'&gt;First-time setup — copies agent pool only. No pipeline-state.json created. Prompts for profile and recipe after deploy.&lt;br&gt;&lt;b&gt;New projects without structured pipeline orchestration&lt;/b&gt;&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingTop=5;verticalAlign=top;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="412" width="490" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="cr_c11"
          value="&lt;font face='Courier New' size='2'&gt;&lt;b&gt;Set Recipe&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style='font-size:10px' color='#555555'&gt;Set or change the delivery recipe at any time (enterprise-dashboard, none, etc.). Re-settable — updates project-config.md.&lt;br&gt;&lt;b&gt;Any project, any time&lt;/b&gt;&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingTop=5;verticalAlign=top;"
          vertex="1" parent="1">
          <mxGeometry x="550" y="412" width="490" height="80" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

