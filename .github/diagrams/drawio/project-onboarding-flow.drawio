        <mxCell id="rp_title" value="Enterprise Dashboard Recipe — 9-Phase Delivery Pipeline"
          style="text;html=1;fontSize=22;fontStyle=1;fontFamily=Arial;align=center;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="80" y="15" width="900" height="42" as="geometry"/>
        </mxCell>

        <mxCell id="rp_subtitle"
          value="Compact reference — shows phase sequence, agents, and key skills. All three run modes (Pipeline · Direct Agent · Open Chat) converge here. For full architecture see: recipe-system-architecture.drawio"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;strokeWidth=1.5;fontSize=11;fontFamily=Arial;fontColor=#555555;"
          vertex="1" parent="1">
