          value="enterprise-dashboard.recipe.md — reads project-config.md → recipe field"
          style="whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D6A656;strokeWidth=1.5;fontSize=11;fontStyle=1;fontFamily=Arial;fontColor=#7D4E00;align=center;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="103" width="1020" height="28" as="geometry"/>
        </mxCell>

        <!-- Phase arrows (back layer) -->
        <mxCell id="rp_a1" style="html=1;endArrow=block;endFill=1;strokeColor=#B85450;strokeWidth=2;" edge="1" source="rp_p1" target="rp_p2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rp_a2" style="html=1;endArrow=block;endFill=1;strokeColor=#B85450;strokeWidth=2;" edge="1" source="rp_p2" target="rp_p3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rp_a3" style="html=1;endArrow=block;endFill=1;strokeColor=#B85450;strokeWidth=2;" edge="1" source="rp_p3" target="rp_p4" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rp_a4" style="html=1;endArrow=block;endFill=1;strokeColor=#B85450;strokeWidth=2;" edge="1" source="rp_p4" target="rp_p5" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rp_a5" style="html=1;endArrow=block;endFill=1;strokeColor=#B85450;strokeWidth=2;" edge="1" source="rp_p5" target="rp_p6" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rp_a6" style="html=1;endArrow=block;endFill=1;strokeColor=#8E44AD;strokeWidth=2;" edge="1" source="rp_p6" target="rp_p7" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rp_a7" style="html=1;endArrow=block;endFill=1;strokeColor=#4472C4;strokeWidth=2;" edge="1" source="rp_p7" target="rp_p8" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rp_a8" style="html=1;endArrow=block;endFill=1;strokeColor=#2D6A2E;strokeWidth=2;" edge="1" source="rp_p8" target="rp_p9" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Phase boxes -->
        <mxCell id="rp_p1" value="&lt;b&gt;1&lt;/b&gt;&lt;br&gt;DATA INTAKE&lt;br&gt;&lt;font style='font-size:9px' color='#888888'&gt;Profile source. Detect adapter type.&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;strokeWidth=1.5;fontSize=11;fontFamily=Arial;verticalAlign=middle;align=center;"
          vertex="1" parent="1"><mxGeometry x="20" y="140" width="106" height="90" as="geometry"/></mxCell>
        <mxCell id="rp_p2" value="&lt;b&gt;2&lt;/b&gt;&lt;br&gt;ADAPTER&lt;br&gt;&lt;font style='font-size:9px' color='#888888'&gt;Extract + type-map raw data.&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;strokeWidth=1.5;fontSize=11;fontFamily=Arial;verticalAlign=middle;align=center;"
          vertex="1" parent="1"><mxGeometry x="134" y="140" width="106" height="90" as="geometry"/></mxCell>
        <mxCell id="rp_p3" value="&lt;b&gt;3&lt;/b&gt;&lt;br&gt;NORMALIZE&lt;br&gt;&lt;font style='font-size:9px' color='#888888'&gt;Clean, coerce, dedup.&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;strokeWidth=1.5;fontSize=11;fontFamily=Arial;verticalAlign=middle;align=center;"
          vertex="1" parent="1"><mxGeometry x="248" y="140" width="106" height="90" as="geometry"/></mxCell>
        <mxCell id="rp_p4" value="&lt;b&gt;4&lt;/b&gt;&lt;br&gt;DISPLAY DTO&lt;br&gt;&lt;font style='font-size:9px' color='#888888'&gt;Define typed DTO for UI.&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;strokeWidth=1.5;fontSize=11;fontFamily=Arial;verticalAlign=middle;align=center;"
          vertex="1" parent="1"><mxGeometry x="362" y="140" width="106" height="90" as="geometry"/></mxCell>
        <mxCell id="rp_p5" value="&lt;b&gt;5&lt;/b&gt;&lt;br&gt;CONTRACT TEST&lt;br&gt;&lt;font style='font-size:9px' color='#888888'&gt;Validate fields, types, constraints.&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;strokeWidth=1.5;fontSize=11;fontFamily=Arial;verticalAlign=middle;align=center;"
          vertex="1" parent="1"><mxGeometry x="476" y="140" width="106" height="90" as="geometry"/></mxCell>
        <mxCell id="rp_p6" value="&lt;b&gt;6&lt;/b&gt;&lt;br&gt;API SURFACE&lt;br&gt;&lt;font style='font-size:9px' color='#888888'&gt;FastAPI endpoint serving the DTO.&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;strokeWidth=1.5;fontSize=11;fontFamily=Arial;verticalAlign=middle;align=center;"
          vertex="1" parent="1"><mxGeometry x="590" y="140" width="106" height="90" as="geometry"/></mxCell>
        <mxCell id="rp_p7" value="&lt;b&gt;7&lt;/b&gt;&lt;br&gt;UI DESIGN&lt;br&gt;&lt;font style='font-size:9px' color='#888888'&gt;Mockup → React. Design system.&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8DAEF;strokeColor=#8E44AD;strokeWidth=1.5;fontSize=11;fontFamily=Arial;verticalAlign=middle;align=center;"
          vertex="1" parent="1"><mxGeometry x="704" y="140" width="106" height="90" as="geometry"/></mxCell>
        <mxCell id="rp_p8" value="&lt;b&gt;8&lt;/b&gt;&lt;br&gt;IMPLEMENT&lt;br&gt;&lt;font style='font-size:9px' color='#888888'&gt;Wire components, data flow, state.&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#4472C4;strokeWidth=1.5;fontSize=11;fontFamily=Arial;verticalAlign=middle;align=center;"
          vertex="1" parent="1"><mxGeometry x="818" y="140" width="106" height="90" as="geometry"/></mxCell>
        <mxCell id="rp_p9" value="&lt;b&gt;9&lt;/b&gt;&lt;br&gt;VERIFY&lt;br&gt;&lt;font style='font-size:9px' color='#888888'&gt;E2E tests, a11y, performance.&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#2D6A2E;strokeWidth=1.5;fontSize=11;fontFamily=Arial;verticalAlign=middle;align=center;"
          vertex="1" parent="1"><mxGeometry x="932" y="140" width="106" height="90" as="geometry"/></mxCell>

        <!-- Agent row -->
        <mxCell id="rp_ag1" value="@Planner" style="text;html=1;fontSize=9;fontColor=#555555;fontFamily=Arial;align=center;" vertex="1" parent="1"><mxGeometry x="20" y="238" width="106" height="16" as="geometry"/></mxCell>
        <mxCell id="rp_ag2" value="@Planner" style="text;html=1;fontSize=9;fontColor=#555555;fontFamily=Arial;align=center;" vertex="1" parent="1"><mxGeometry x="134" y="238" width="106" height="16" as="geometry"/></mxCell>
        <mxCell id="rp_ag3" value="@Implement" style="text;html=1;fontSize=9;fontColor=#555555;fontFamily=Arial;align=center;" vertex="1" parent="1"><mxGeometry x="248" y="238" width="106" height="16" as="geometry"/></mxCell>
        <mxCell id="rp_ag4" value="@Implement" style="text;html=1;fontSize=9;fontColor=#555555;fontFamily=Arial;align=center;" vertex="1" parent="1"><mxGeometry x="362" y="238" width="106" height="16" as="geometry"/></mxCell>
        <mxCell id="rp_ag5" value="@Tester" style="text;html=1;fontSize=9;fontColor=#555555;fontFamily=Arial;align=center;" vertex="1" parent="1"><mxGeometry x="476" y="238" width="106" height="16" as="geometry"/></mxCell>
        <mxCell id="rp_ag6" value="@Implement" style="text;html=1;fontSize=9;fontColor=#555555;fontFamily=Arial;align=center;" vertex="1" parent="1"><mxGeometry x="590" y="238" width="106" height="16" as="geometry"/></mxCell>
        <mxCell id="rp_ag7" value="@Frontend Dev" style="text;html=1;fontSize=9;fontColor=#555555;fontFamily=Arial;align=center;" vertex="1" parent="1"><mxGeometry x="704" y="238" width="106" height="16" as="geometry"/></mxCell>
        <mxCell id="rp_ag8" value="@Frontend Dev" style="text;html=1;fontSize=9;fontColor=#555555;fontFamily=Arial;align=center;" vertex="1" parent="1"><mxGeometry x="818" y="238" width="106" height="16" as="geometry"/></mxCell>
