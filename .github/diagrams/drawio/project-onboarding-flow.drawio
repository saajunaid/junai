  <diagram name="Recipe: 9 Phases" id="recipe-phases">
    <mxGraphModel defaultFontFamily="Arial" dx="0" dy="0" page="1" pageScale="1" pageWidth="1060" pageHeight="420" math="0" shadow="0">
