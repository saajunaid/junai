<mxfile>
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- PAGE 1 — New Project (full SAAR flow)                              -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <diagram name="New Project" id="onboarding-flow">
    <mxGraphModel defaultFontFamily="Arial" dx="0" dy="0" page="1" pageScale="1" pageWidth="1060" pageHeight="1560" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- TITLE                                           -->
        <!-- ═══════════════════════════════════════════════ -->
        <mxCell id="title" value="Project Onboarding — New Project"
          style="text;html=1;fontSize=22;fontStyle=1;fontFamily=Arial;align=center;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="80" y="15" width="900" height="42" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- ARROWS — back layer                             -->
        <!-- ═══════════════════════════════════════════════ -->
        <mxCell id="arr_1_2" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#82B366;strokeWidth=2;rounded=1;" edge="1" source="step1" target="step2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arr_2_3" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#555555;strokeWidth=2;rounded=1;" edge="1" source="step2" target="step3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arr_3_4" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#6C8EBF;strokeWidth=2;rounded=1;" edge="1" source="step3" target="step4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arr_4_5" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#6C8EBF;strokeWidth=2;rounded=1;" edge="1" source="step4" target="step5" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arr_5_6" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#555555;strokeWidth=2;rounded=1;" edge="1" source="step5" target="step6" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arr_6_7" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#D6A656;strokeWidth=2;rounded=1;" edge="1" source="step6" target="step7" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arr_7_8" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#D6A656;strokeWidth=2;rounded=1;" edge="1" source="step7" target="step8" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arr_8_9" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#555555;strokeWidth=2;rounded=1;" edge="1" source="step8" target="step9" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Decision → Pipeline (left) -->
        <mxCell id="arr_9_9a" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#B85450;strokeWidth=2;rounded=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="step9" target="step9a" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arr_9_9a_lbl" value="Pipeline" style="edgeLabel;html=1;fontSize=10;fontFamily=Arial;fontColor=#B85450;fontStyle=1;resizable=0;" vertex="1" connectable="0" parent="arr_9_9a">
          <mxGeometry relative="0.4" as="geometry"/>
        </mxCell>

        <!-- Decision → Direct agents (bottom/centre) -->
        <mxCell id="arr_9_9c" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#4472C4;strokeWidth=2;rounded=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="step9" target="step9c" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arr_9_9c_lbl" value="Direct agents" style="edgeLabel;html=1;fontSize=10;fontFamily=Arial;fontColor=#4472C4;fontStyle=1;resizable=0;" vertex="1" connectable="0" parent="arr_9_9c">
          <mxGeometry relative="0.5" as="geometry"/>
        </mxCell>

        <!-- Decision → Open chat (right) -->
        <mxCell id="arr_9_9b" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#2D6A2E;strokeWidth=2;rounded=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="step9" target="step9b" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arr_9_9b_lbl" value="Open chat" style="edgeLabel;html=1;fontSize=10;fontFamily=Arial;fontColor=#2D6A2E;fontStyle=1;resizable=0;" vertex="1" connectable="0" parent="arr_9_9b">
          <mxGeometry relative="0.4" as="geometry"/>
        </mxCell>

        <!-- All three branches → step10 -->
        <mxCell id="arr_9a_10" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#B85450;strokeWidth=2;rounded=1;entryX=0.15;entryY=0;entryDx=0;entryDy=0;" edge="1" source="step9a" target="step10" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arr_9c_10" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#4472C4;strokeWidth=2;rounded=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="step9c" target="step10" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arr_9b_10" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#2D6A2E;strokeWidth=2;rounded=1;entryX=0.85;entryY=0;entryDx=0;entryDy=0;" edge="1" source="step9b" target="step10" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- PHASE 1 — SCAFFOLD                              -->
        <!-- label: x=20 w=110 (horizontal, no rotation)    -->
        <!-- steps: x=145 w=895                              -->
        <!-- band: y=75 h=250                                -->
        <!-- ═══════════════════════════════════════════════ -->
        <mxCell id="phase1_bg" value=""
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;strokeWidth=2;arcSize=2;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="75" width="1020" height="250" as="geometry"/>
        </mxCell>
        <mxCell id="phase1_lbl" value="SCAFFOLD"
          style="whiteSpace=wrap;html=1;fillColor=#A9D18E;strokeColor=#82B366;strokeWidth=1;fontSize=14;fontStyle=1;fontFamily=Arial;fontColor=#1E4620;align=center;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="75" width="110" height="250" as="geometry"/>
        </mxCell>

        <mxCell id="step1"
          value="&lt;b&gt;① Bootstrap — platform-infra&lt;/b&gt;&lt;br&gt;&lt;font face='Courier New' size='2' color='#2A2A2A'&gt;cd E:\Projects\platform-infra&lt;br&gt;.\bootstrap\new-vmie-project.ps1 -ProjectName &quot;my-project&quot; -ProjectShort &quot;mypr&quot; -Description &quot;My project&quot; -Port 0&lt;/font&gt;&lt;br&gt;&lt;font color='#7D4E00' style='font-size:10px'&gt;&lt;b&gt;Optional flags&lt;/b&gt; — only add if you want to skip something:  -Validate (dry run, no files created)  ·  -NoFrontend (skip React/Vite)  ·  -SkipGitea (skip Gitea repo)  ·  -NoAuth (skip auth layer)&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingRight=8;spacingTop=5;spacingBottom=5;"
          vertex="1" parent="1">
          <mxGeometry x="145" y="105" width="865" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="step2"
          value="&lt;b&gt;② Scaffold created automatically&lt;/b&gt;&lt;br&gt;&lt;font color='#555555' style='font-size:11px'&gt;project-template copied  ·  .venv created + pip install  ·  npm install  ·  port allocated in port-registry.json  ·  Gitea repo created &amp;amp; initial commit pushed &lt;i&gt;&lt;font color='#B85450'&gt;(omitted if -SkipGitea)&lt;/font&gt;&lt;/i&gt;&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingRight=8;spacingTop=5;spacingBottom=5;"
          vertex="1" parent="1">
          <mxGeometry x="145" y="207" width="865" height="88" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- PHASE 2 — ACTIVATE                              -->
        <!-- band: y=345 h=305                               -->
        <!-- ═══════════════════════════════════════════════ -->
        <mxCell id="phase2_bg" value=""
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;strokeWidth=2;arcSize=2;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="345" width="1020" height="310" as="geometry"/>
        </mxCell>
        <mxCell id="phase2_lbl" value="ACTIVATE"
          style="whiteSpace=wrap;html=1;fillColor=#9DC3E6;strokeColor=#6C8EBF;strokeWidth=1;fontSize=14;fontStyle=1;fontFamily=Arial;fontColor=#1F3864;align=center;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="345" width="110" height="310" as="geometry"/>
        </mxCell>

        <mxCell id="step3"
          value="&lt;b&gt;③ Open project in VS Code&lt;/b&gt;&lt;br&gt;&lt;font face='Courier New' size='2' color='#2A2A2A'&gt;code E:\Projects\my-project&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6C8EBF;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingRight=8;spacingTop=5;spacingBottom=5;"
          vertex="1" parent="1">
          <mxGeometry x="145" y="375" width="865" height="62" as="geometry"/>
        </mxCell>
        <mxCell id="step4"
          value="&lt;b&gt;④ Initialize junai — pick ONE command based on your intent&lt;/b&gt;&lt;br&gt;&lt;font color='#1E4620' style='font-size:10px'&gt;▶ &lt;b&gt;junai: Initialize Agent Pipeline&lt;/b&gt; (VS Code notification or Ctrl+Shift+P) — full pool + recipe framework + pipeline-state.json   &lt;b&gt;← new projects (default)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color='#7D4E00' style='font-size:10px'&gt;▶ &lt;b&gt;junai: Initialize Agent Pool&lt;/b&gt; — pool only, no pipeline-state.json — AI assistance without structured orchestration&lt;/font&gt;&lt;br&gt;&lt;font color='#1F3864' style='font-size:10px'&gt;▶ &lt;b&gt;junai: Update Agent Pool&lt;/b&gt; — syncs latest agent/skill versions only — &lt;b&gt;for already-initialized or mid-flight projects only&lt;/b&gt;&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6C8EBF;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingRight=8;spacingTop=5;spacingBottom=5;"
          vertex="1" parent="1">
          <mxGeometry x="145" y="452" width="865" height="115" as="geometry"/>
        </mxCell>
        <mxCell id="step5"
          value="&lt;b&gt;⑤ Pool deployed by &quot;Initialize Agent Pipeline&quot; (no further command needed)&lt;/b&gt;&lt;br&gt;&lt;font color='#555555' style='font-size:11px'&gt;agents/ · skills/ · recipes/ · instructions/ → .github/  |  .claude/  |  .codex/  ·  .vscode/mcp.json  ·  pipeline-state.json  ·  project-config.md&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6C8EBF;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingRight=8;spacingTop=5;spacingBottom=5;"
          vertex="1" parent="1">
          <mxGeometry x="145" y="582" width="865" height="63" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- PHASE 3 — AIM                                   -->
        <!-- band: y=675 h=335                               -->
        <!-- ═══════════════════════════════════════════════ -->
        <mxCell id="phase3_bg" value=""
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D6A656;strokeWidth=2;arcSize=2;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="675" width="1020" height="340" as="geometry"/>
        </mxCell>
        <mxCell id="phase3_lbl" value="AIM"
          style="whiteSpace=wrap;html=1;fillColor=#F4C07A;strokeColor=#D6A656;strokeWidth=1;fontSize=14;fontStyle=1;fontFamily=Arial;fontColor=#7D4E00;align=center;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="675" width="110" height="340" as="geometry"/>
        </mxCell>

        <mxCell id="step6"
          value="&lt;b&gt;⑥ Select Project Profile&lt;/b&gt;&lt;br&gt;&lt;font face='Courier New' size='2' color='#2A2A2A'&gt;Ctrl+Shift+P → &quot;junai: Select Project Profile&quot;&lt;/font&gt;&lt;br&gt;&lt;font color='#555555' style='font-size:11px'&gt;QuickPick: react-fastapi-vite-mssql  ·  streamlit-mssql-enterprise  ·  org1-telecom-ops  ·  …&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D6A656;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingRight=8;spacingTop=5;spacingBottom=5;"
          vertex="1" parent="1">
          <mxGeometry x="145" y="705" width="865" height="82" as="geometry"/>
        </mxCell>
        <mxCell id="step7"
          value="&lt;b&gt;⑦ Select Recipe (QuickPick prompted automatically after profile)&lt;/b&gt;&lt;br&gt;&lt;font color='#555555' style='font-size:11px'&gt;QuickPick: enterprise-dashboard (9-phase)  ·  none (skip)&lt;/font&gt;&lt;br&gt;&lt;font face='Courier New' size='2' color='#555555'&gt;Written to: .github/project-config.md  →  | recipe | enterprise-dashboard |&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D6A656;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingRight=8;spacingTop=5;spacingBottom=5;"
          vertex="1" parent="1">
          <mxGeometry x="145" y="802" width="865" height="82" as="geometry"/>
        </mxCell>
        <mxCell id="step8"
          value="&lt;b&gt;⑧ Place your assets in scratch/&lt;/b&gt;&lt;br&gt;&lt;font face='Courier New' size='2' color='#2A2A2A'&gt;scratch/data/     ←  CSV · JSON · XLSX · or note your DB host + table name(s)&lt;br&gt;scratch/mockups/  ←  dashboard-mockup.html&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D6A656;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingRight=8;spacingTop=5;spacingBottom=5;"
          vertex="1" parent="1">
          <mxGeometry x="145" y="899" width="865" height="86" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- PHASE 4 — RUN                                   -->
        <!-- band: y=1035 h=450                              -->
        <!-- ═══════════════════════════════════════════════ -->
        <mxCell id="phase4_bg" value=""
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;strokeWidth=2;arcSize=2;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="1035" width="1020" height="455" as="geometry"/>
        </mxCell>
        <mxCell id="phase4_lbl" value="RUN"
          style="whiteSpace=wrap;html=1;fillColor=#E8928E;strokeColor=#B85450;strokeWidth=1;fontSize=14;fontStyle=1;fontFamily=Arial;fontColor=#7A1F1F;align=center;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="1035" width="110" height="455" as="geometry"/>
        </mxCell>

        <!-- Decision diamond — centered on steps area: x=145 w=895, center=142+447=589 -->
        <mxCell id="step9"
          value="&lt;b&gt;⑨ How do you want to work?&lt;/b&gt;"
          style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B85450;strokeWidth=2;fontSize=13;fontFamily=Arial;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="444" y="1068" width="290" height="72" as="geometry"/>
        </mxCell>

        <!-- Branch A: Full Pipeline -->
        <mxCell id="step9a"
          value="&lt;b&gt;Full Pipeline&lt;/b&gt;&lt;br&gt;&lt;font face='Courier New' size='2' color='#7A1F1F'&gt;@Orchestrator Start a new pipeline.&lt;br&gt;Data in scratch/data/, mockup in&lt;br&gt;scratch/mockups/. Build [feature].&lt;/font&gt;&lt;br&gt;&lt;font color='#888888' style='font-size:10px'&gt;Stage machine controls routing + gates&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B85450;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingRight=8;spacingTop=5;spacingBottom=5;"
          vertex="1" parent="1">
          <mxGeometry x="145" y="1188" width="255" height="110" as="geometry"/>
        </mxCell>

        <!-- Branch B: Direct Agent Call -->
        <mxCell id="step9c"
          value="&lt;b&gt;Direct Agent Call&lt;/b&gt;&lt;br&gt;&lt;font face='Courier New' size='2' color='#1F3864'&gt;@Implement [describe the task]&lt;br&gt;@Planner Plan the [feature]&lt;br&gt;@Frontend Developer Build [UI]&lt;/font&gt;&lt;br&gt;&lt;font color='#888888' style='font-size:10px'&gt;Agents + skills load, no state machine&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4472C4;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingRight=8;spacingTop=5;spacingBottom=5;"
          vertex="1" parent="1">
          <mxGeometry x="432" y="1188" width="255" height="110" as="geometry"/>
        </mxCell>

        <!-- Branch C: Open Chat -->
        <mxCell id="step9b"
          value="&lt;b&gt;Open Chat (any AI tool)&lt;/b&gt;&lt;br&gt;&lt;font face='Courier New' size='2' color='#1E4620'&gt;Build [feature]. Data in scratch/data/.&lt;br&gt;Mockup in scratch/mockups/.&lt;br&gt;Follow the enterprise-dashboard recipe.&lt;/font&gt;&lt;br&gt;&lt;font color='#888888' style='font-size:10px'&gt;Claude Code · Cursor · Windsurf · Copilot&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2D6A2E;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingRight=8;spacingTop=5;spacingBottom=5;"
          vertex="1" parent="1">
          <mxGeometry x="720" y="1188" width="265" height="110" as="geometry"/>
        </mxCell>

        <!-- Converge -->
        <mxCell id="step10"
          value="&lt;b&gt;⑩ Recipe guides delivery — all three paths converge here&lt;/b&gt;&lt;br&gt;&lt;font color='#555555' style='font-size:11px'&gt;Reads project-config.md → recipe field → follows phases:  1. Data Intake → 2. Adapter → 3. Normalize → 4. Display DTO → 5. Contract Test → 6. API Surface → 7. UI Design → 8. Implement → 9. Verify&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B85450;strokeWidth=1.5;fontSize=12;fontFamily=Arial;align=left;spacingLeft=8;spacingRight=8;spacingTop=5;spacingBottom=5;"
          vertex="1" parent="1">
          <mxGeometry x="145" y="1335" width="865" height="120" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- NOTE                                            -->
        <!-- ═══════════════════════════════════════════════ -->
        <mxCell id="note"
          value="&lt;i&gt;No recipe set? Agents use built-in expertise. Recipe is optional, not required.  ·  Pool updates? Extension auto-updates on workspace open — no manual steps.&lt;/i&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;strokeWidth=1.5;fontSize=12;fontFamily=Arial;fontColor=#666666;"
          vertex="1" parent="1">
          <mxGeometry x="145" y="1510" width="865" height="36" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- PAGE 2 — Existing Project Adoption (mid-project on-ramp)           -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <diagram name="Existing Project" id="midproject-flow">
    <mxGraphModel defaultFontFamily="Arial" dx="0" dy="0" page="1" pageScale="1" pageWidth="1060" pageHeight="1470" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- TITLE                                           -->
        <!-- ═══════════════════════════════════════════════ -->
        <mxCell id="m_title" value="Adopting junai — Existing Project (no bootstrap)"
          style="text;html=1;fontSize=22;fontStyle=1;fontFamily=Arial;align=center;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="80" y="15" width="900" height="42" as="geometry"/>
        </mxCell>
        <mxCell id="m_subtitle"
          value="Use this flow when you already have a project underway and want to adopt junai agents, skills, and recipes mid-development. &lt;b&gt;Use &quot;junai: Update Agent Pool&quot; — NOT &quot;Initialize Agent Pipeline&quot; — to avoid overwriting existing context.&lt;/b&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;strokeWidth=1.5;fontSize=12;fontFamily=Arial;fontColor=#555555;"
          vertex="1" parent="1">
          <mxGeometry x="145" y="60" width="865" height="38" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- ARROWS — back layer                             -->
        <!-- ═══════════════════════════════════════════════ -->
        <mxCell id="m_arr_1_2" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#7B7B7B;strokeWidth=2;rounded=1;" edge="1" source="mstep1" target="mstep2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="m_arr_2_3" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#555555;strokeWidth=2;rounded=1;" edge="1" source="mstep2" target="mstep3" parent="1">
