      "name": "claude",
      "_comment": "Claude Code bundle — the lean Phase 0-2 harness (subagents + commands + CLAUDE.md fragments) sourced from claude-harness/, plus the tiered dev skill set (core + frontend) from .github/skills. Flat layout (workspace_root='.') feeds Phase 4 plugin packaging. Skills tier table: .github/plans/phase-3-commands-skills-export.md §Step 1.",
      "_comment_private": "No include_private here: the core bundle is public, so the private vmie/ category is excluded. golden-workflow and vm-ppt (proprietary: internal hostnames/repos, third-party .pptx) live in vmie/ (private, local-use only) and are NOT published in any public bundle. windows-deployment is a generic Windows deploy skill (the vmie service-name prefix is just an example NSSM convention) and stays in the public core (devops).",
      "_comment_layout": "Two-level bundle: marketplace.json at the bundle root (= junai repo root after publish), the plugin under plugin/ (= junai/plugin/). The junai repo hosts other content (.github mirror, src/), so the plugin cannot sit at repo root with source '.'; it lives in plugin/ and the marketplace points there.",
      "workspace_root": "plugin",
      "extra_roots": { "harness": "claude-harness", "scriptsrc": "scripts" },
      "plugin": {
        "name": "claudster",
        "version": "1.3.23",
        "description": "claudster — agent-agnostic dev harness: lean subagents, TDD commands, tiered skills, and a CLAUDE.md generator.",
        "author": { "name": "junaid", "url": "https://github.com/saajunaid/junai" },
        "homepage": "https://github.com/saajunaid/junai",
        "repository": "https://github.com/saajunaid/junai",
        "license": "MIT",
        "keywords": ["harness", "subagents", "tdd", "fastapi", "react", "claude-code", "agent-agnostic"]
      },
      "marketplace": {
        "name": "claudster",
        "owner": { "name": "junaid" },
        "description": "claudster plugin marketplace",
        "plugins": [
          {"name": "claudster", "source": "./plugin", "description": "claudster — agent-agnostic dev harness: lean subagents, TDD commands, a core dev skill set, loop hooks, and a CLAUDE.md generator."},
          {"name": "claudster-extras", "source": "./plugin-extras", "description": "claudster-extras — the full claudster skill library (cloud, data, the long tail of frontend/coding, media, productivity). Disabled by default; enable on demand to keep always-on context lean."}
        ]
      },
      "files": [
        {"root": "harness", "source": "settings.template.json", "destination": "settings.template.json"},
        {"root": "harness", "source": "stack-map.json", "destination": "stack-map.json"},
        {"root": "harness", "source": "litellm.config.example.yaml", "destination": "litellm.config.example.yaml"},
        {"root": "harness", "source": "LOCAL-MODELS.md", "destination": "LOCAL-MODELS.md"},
        {"root": "harness", "source": "statusline-command.sh", "destination": "statusline-command.sh"},
        {"root": "harness", "source": "README.md", "destination": "README.md"},
        {"root": "scriptsrc", "source": "setup_project_ai.py", "destination": "scripts/setup_project_ai.py"},
        {"root": "scriptsrc", "source": "usage_review.py",     "destination": "scripts/usage_review.py"},
        {"root": "harness",   "source": "scripts/check_doc_coverage.py", "destination": "scripts/check_doc_coverage.py"},
        {"root": "harness",   "source": "scripts/dream_memory.py",     "destination": "scripts/dream_memory.py"},
        {"root": "harness",   "source": "scripts/dream_capture.py",    "destination": "scripts/dream_capture.py"},
        {"root": "harness",   "source": "scripts/claudster_config.py", "destination": "scripts/claudster_config.py"}
      ],
      "copies": [
        {"root": "harness", "source": "agents", "destination": "agents"},
        {"root": "harness", "source": "commands", "destination": "commands"},
        {"root": "harness", "source": "claude-md", "destination": "claude-md"},
        {"root": "harness", "source": "hooks", "destination": "hooks", "excluded_names": ["notify.py"]},
        {
          "_comment": "CORE tier — ~38 high-frequency dev skills, flattened to skills/<name>/ so Claude Code's plugin loader (flat discovery) actually registers them. The long tail lives in the claude-extras target. Office skills (pdf/docx/pptx/xlsx) are Anthropic-proprietary and ship via Anthropic's own document-skills, not here.",
          "source": "skills",
          "destination": "skills",
          "flatten_skills": true,
          "included_skills": {
            "coding": [
              "api-design", "backend-development", "code-review", "codebase-audit", "error-handling",
              "fastapi-dev", "javascript-typescript", "python", "refactoring", "security-review", "sql"
            ],
            "testing": [
              "playwright", "tdd-workflow", "test-strategy", "webapp-testing"
            ],
            "workflow": [
              "best-practices", "brainstorming", "context-curator", "golden-plan", "preflight",
              "skill-creator"
            ],
            "docs": [
              "code-documentation", "technical-writing", "writing-plans"
            ],
            "devops": [
              "ci-cd-pipeline", "gh-cli", "git-commit", "using-git-worktrees", "windows-deployment"
            ],
            "data": [
              "database-design"
            ],
            "frontend": [
              "css-architecture", "frontend-design", "mockup", "react-best-practices", "react-dev",
              "ui-review", "warm-editorial-ui"
            ],
            "media": [
              "draw-io", "mermaid-diagrams", "particle-art"
            ]
          }
        }
      ]
    },
    {
      "name": "claude-extras",
      "_comment": "EXTRAS tier — the full skill library MINUS the core (and minus the proprietary document-skills bundle). Ships as a second plugin (claudster-extras) under plugin-extras/, listed in the same marketplace. Disabled by default; users enable it on demand so the long tail costs zero always-on context. Skills-only: agents/commands/hooks live in the core plugin. Uses excluded_skills (denylist) rather than an allowlist so new pool skills join extras automatically.",
      "_comment_private": "No include_private / no purge: the private vmie/ category (golden-workflow, vm-ppt) is globally excluded, so none of these proprietary skills ship to extras. New non-vmie pool skills still join extras automatically via the everything-minus-core denylist.",
      "workspace_root": "plugin-extras",
      "plugin": {
        "name": "claudster-extras",
        "version": "1.3.3",
        "description": "claudster-extras — the full claudster skill library beyond the core tier (cloud, data, the long tail of coding/frontend, media, productivity). Enable on demand to keep always-on context lean.",
        "author": { "name": "junaid", "url": "https://github.com/saajunaid/junai" },
        "homepage": "https://github.com/saajunaid/junai",
        "repository": "https://github.com/saajunaid/junai",
        "license": "MIT",
        "keywords": ["claudster", "skills", "extras", "claude-code"]
      },
      "copies": [
        {
          "_comment": "Everything except the core 38 and the proprietary document-skills bundle. document-skills is excluded because it is a 3-level nested bundle (docs/document-skills/<pdf|docx|pptx|xlsx>) of Anthropic-proprietary skills that neither flatten nor belong in a public bundle.",
          "source": "skills",
