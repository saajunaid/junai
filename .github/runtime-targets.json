      "vmie"
    ],
    "private_roots": [
      "vmie"
    ],
    "private_paths": [
      "plans"
    ]
  },
  "targets": [
    {
      "name": "copilot",
      "workspace_root": ".github",
      "files": [
        {"source": "project-config.md", "destination": "project-config.md"},
        {"source": "agent-docs/README.md", "destination": "agent-docs/README.md"},
        {"source": "handoffs/README.md", "destination": "handoffs/README.md"}
