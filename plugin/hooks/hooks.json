{
  "description": "claudster harness loop, auto-activated on install: relay.md session-resume injection (SessionStart + PreCompact), subagent verdict logging (SubagentStop → agent-log.jsonl, powers /agent-log), a session-end nudge (Stop), and post-edit lint (PostToolUse on Edit/Write). All handlers are pure-Python and cross-platform; they require `python` on PATH.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/inject_relay.py\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/inject_relay.py\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/agent_log.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/session_end.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/auto_lint.py\""
          }
        ]
      }
    ]
  }
}
