{
  "$comment": "Stack-detection signals → harness pieces. setup_project_ai.py reads this. Each detector lists file globs / dependency tokens; when matched, the listed fragments are composed into the named target CLAUDE.md, and the listed settings_allow entries are merged into .claude/settings.json.",
  "always": {
    "root_fragment": "root.md.tmpl",
    "agents_mirror": "agents.md.tmpl",
    "subagents": ["tester.md", "code-reviewer.md", "preflight.md", "security-analyst.md", "codebase-audit.md", "debug.md", "anchor.md", "knowledge-transfer.md", "data-engineer.md", "sql-expert.md"],
    "commands": ["feature-plan.md", "tdd.md", "prd.md", "handoff.md", "setup-project-ai.md", "agent-log.md"]
  },
  "detectors": [
    {
      "id": "python-backend",
      "any_path": ["pyproject.toml", "requirements.txt", "setup.py", "src/**/*.py"],
      "target": "src/CLAUDE.md",
      "fragments": ["backend-python.md"],
      "settings_allow": ["Bash(python:*)", "Bash(python -m pytest:*)", "Bash(ruff:*)"]
    },
    {
      "id": "fastapi",
      "any_dep": ["fastapi"],
      "target": "src/CLAUDE.md",
      "fragments": ["backend-fastapi.md"],
      "settings_allow": []
    },
    {
      "id": "pytest",
      "any_dep": ["pytest"],
      "any_path": ["tests/**", "conftest.py"],
      "target": "tests/CLAUDE.md",
      "fragments": ["tests-pytest.md"],
      "settings_allow": ["Bash(pytest:*)"]
    },
    {
      "id": "react-frontend",
      "any_path": ["frontend/package.json", "package.json"],
      "any_dep_json": ["react"],
      "target": "frontend/CLAUDE.md",
      "fragments": ["frontend-react.md"],
      "settings_allow": ["Bash(npm test:*)", "Bash(npm run build:*)", "Bash(npx vitest:*)"]
    }
  ],
  "frontend_test_harness": {
    "$comment": "Phase 0 friction #4: frontend lists vitest+testing-library but has no DOM env. When react+vitest detected but no jsdom/setup, the generator scaffolds it.",
    "trigger_dep_any": ["vitest"],
    "require_dep_any": ["jsdom", "happy-dom"],
    "ensure_dev_deps": ["jsdom", "@testing-library/jest-dom"],
    "setup_file": "src/test/setup.ts"
  }
}
